{
  "mcpServers": {
{% for server in settings.custom_mcp_servers %}
    "{{ server.name }}": {
      "command": "{{ server.command }}",
      "args": {{ server.args | to_json }}{% if server.env is defined %},
      "env": {{ server.env | to_json }}
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  }
}
